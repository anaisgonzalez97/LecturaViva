<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Chips de filtro -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp">

        <com.google.android.material.chip.ChipGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip android:id="@+id/chipAll"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/chip_all" style="@style/Widget.LecturaViva.Chip"
                android:checked="true"/>
            <com.google.android.material.chip.Chip android:id="@+id/chipReading"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/chip_reading" style="@style/Widget.LecturaViva.Chip"/>
            <com.google.android.material.chip.Chip android:id="@+id/chipPending"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/chip_pending" style="@style/Widget.LecturaViva.Chip"/>
            <com.google.android.material.chip.Chip android:id="@+id/chipRead"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/chip_read" style="@style/Widget.LecturaViva.Chip"/>
            <com.google.android.material.chip.Chip android:id="@+id/chipFavorites"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/chip_favorites" style="@style/Widget.LecturaViva.Chip"/>
            <com.google.android.material.chip.Chip android:id="@+id/chipAbandoned"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/chip_abandoned" style="@style/Widget.LecturaViva.Chip"/>
        </com.google.android.material.chip.ChipGroup>
    </HorizontalScrollView>

    <!-- Buscador -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/hint_search_books"
        app:startIconDrawable="@drawable/ic_search"
        style="@style/Widget.LecturaViva.TextInput"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        app:startIconTint="@color/green_med">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:imeOptions="actionSearch"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Lista -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"/>

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/label_empty_library"
            android:gravity="center"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:padding="32dp"
            android:visibility="gone"/>
    </FrameLayout>
</LinearLayout>
